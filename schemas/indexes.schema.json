{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pinake Search Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "documents",
    "terms"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "headings",
          "keywords",
          "id"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "headings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "id": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "terms": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
