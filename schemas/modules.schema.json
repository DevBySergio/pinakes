{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pinake Modules State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "installedModules"
  ],
  "properties": {
    "installedModules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "version",
          "config"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "config": {
            "type": "object"
          }
        }
      }
    }
  }
}
