{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pinake Migrations State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "currentVersion",
    "history"
  ],
  "properties": {
    "currentVersion": {
      "type": "string"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "version",
          "upgradedAt",
          "notes"
        ],
        "properties": {
          "version": {
            "type": "string"
          },
          "upgradedAt": {
            "type": "string",
            "format": "date-time"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
